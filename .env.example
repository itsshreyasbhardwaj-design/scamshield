# ScamShield — copy to .env and fill in. EVERYTHING here is optional:
# with no keys the app runs fully offline (mock reputation, template
# explanations, in-memory store). Never commit your real .env.

ENV=development
APP_NAME=ScamShield
DEFAULT_COUNTRY=IN
DEFAULT_LANGUAGE=en           # en | hi | hinglish

# --- LLM explanations (free OpenAI-compatible tier via agentcore) ---
# Leave LLM_PROVIDER=mock for deterministic offline template explanations.
LLM_PROVIDER=mock             # mock | openai | claude
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=               # e.g. Groq gsk_... (free) or Gemini AIza... key
OPENAI_MODEL=llama-3.3-70b-versatile
EXPLANATION_TIMEOUT=8.0

# --- Link/threat reputation (Google Safe Browsing, free with a key) ---
SAFE_BROWSING_API_KEY=        # empty => MockReputation (offline)

# --- Supabase (Postgres + Auth + RLS). Empty => in-memory store ---
SUPABASE_URL=
SUPABASE_ANON_KEY=            # public, safe to expose to clients
SUPABASE_SERVICE_ROLE_KEY=    # SERVER ONLY — never ship to the browser

# --- Monitoring ---
SENTRY_DSN=

# --- Privacy / limits ---
STORE_RAW_DEFAULT=false       # raw message storage is opt-in per scan
RATE_LIMIT_PER_MIN=20
RATE_LIMIT_PER_DAY=500
ALLOWED_ORIGINS=*
